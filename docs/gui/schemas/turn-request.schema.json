{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seelex.dev/schemas/turn-request.schema.json",
  "title": "Submit session turn request",
  "type": "object",
  "additionalProperties": false,
  "required": ["input", "client_request_id"],
  "properties": {
    "input": { "type": "string", "minLength": 1, "maxLength": 100000 },
    "client_request_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "skills": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "common.schema.json#/$defs/identifier" },
      "uniqueItems": true
    }
  }
}
