{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seelex.dev/schemas/module-dotting.schema.json",
  "title": "Seelex module registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "system", "modules"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "integer", "const": 1 },
    "system": { "type": "string", "const": "seelex-agent-workbench" },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/module" }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "name", "status", "responsibility", "document",
        "interfaces", "planned_paths", "inputs", "outputs", "depends_on"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["implemented", "partial", "planned", "deprecated"] },
        "responsibility": { "type": "string", "minLength": 10 },
        "document": { "type": "string", "pattern": "^modules/.+\\.md$" },
        "interfaces": { "$ref": "#/$defs/stringList" },
        "planned_paths": { "$ref": "#/$defs/stringList" },
        "inputs": { "$ref": "#/$defs/stringList" },
        "outputs": { "$ref": "#/$defs/stringList" },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      }
    }
  }
}
