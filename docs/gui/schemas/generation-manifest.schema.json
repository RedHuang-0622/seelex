{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seelex.dev/schemas/generation-manifest.schema.json",
  "title": "Seelex immutable generation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_version", "generation_id", "session_id", "state", "created_at", "created_by", "resources", "content_sha256"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "protocol_version": { "$ref": "common.schema.json#/$defs/protocolVersion" },
    "generation_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "parent_generation_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "session_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "state": { "const": "committed" },
    "created_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "created_by": { "$ref": "common.schema.json#/$defs/identifier" },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resource" }
    },
    "content_sha256": { "$ref": "common.schema.json#/$defs/sha256" },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "media_type", "bytes", "sha256"],
      "properties": {
        "path": { "$ref": "common.schema.json#/$defs/relativePath" },
        "media_type": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "common.schema.json#/$defs/sha256" }
      }
    }
  }
}
